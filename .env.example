# --- Identity ---
GITHUB_USERNAME=atm241
LEETCODE_USERNAME=atm241

# Optional: raises GitHub API rate limit from 60 to 5000 req/hour.
# Create at https://github.com/settings/tokens (no scopes needed for public data).
GITHUB_TOKEN=

# --- Auth (job tracker is private; this is your login) ---
ADMIN_PASSWORD=change-me
JWT_SECRET=generate-a-long-random-string

# --- Database ---
DATABASE_URL=postgres://portfolio:portfolio@localhost:5432/portfolio
# Used by docker-compose's postgres container:
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio

# --- Server ---
PORT=3001
